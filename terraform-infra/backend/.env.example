# AIonOS Platform - Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT put real credentials here

APP_NAME=AIonOS Platform
APP_VERSION=1.0.0
DEBUG=false
PLATFORM_ENV=development

SECRET_KEY=generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DATABASE_URL=sqlite:///./platform.db

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=ap-south-1

TF_STATE_BUCKET=your-terraform-state-bucket
TF_DYNAMO_TABLE=your-dynamodb-lock-table
TF_PROJECT_ROOT=D:\AWS_Terraform_automation\terraform-infra
TF_WORKSPACES_DIR=D:\AWS_Terraform_automation\terraform-infra\backend\terraform\workspaces

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Azure ─────────────────────────────────────────────────────────────────
# Shared across all 3 subscriptions
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Production Subscription
AZURE_PROD_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_PROD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_PROD_CLIENT_SECRET=your-prod-client-secret

# Non-Production Subscription
AZURE_NONPROD_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_NONPROD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_NONPROD_CLIENT_SECRET=your-nonprod-client-secret

# Connectivity Subscription (Hub Networking)
AZURE_CONNECTIVITY_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CONNECTIVITY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CONNECTIVITY_CLIENT_SECRET=your-connectivity-client-secret

# ── Email / SMTP (for utilization + budget alerts) ────────────────────────
# Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AIonOS Platform <your-email@gmail.com>

# ── GCP ──────────────────────────────────────────────────────────────────
# Your GCP project ID (e.g. my-project-123456)
GCP_PROJECT_ID=your-gcp-project-id

# Service account key JSON (paste the entire JSON on a single line, or use a file path)
# To generate: GCP Console → IAM → Service Accounts → Create → Download JSON key
# Then: cat key.json | tr -d '\n' to flatten it
GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}
